// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Alunos {
  id        Int       @id @default(autoincrement())
  nome      String
  idade     Int 
  cpf       Int       @unique
  email     String    @unique
  creatdAt  DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  alunosCursos AlunosCursos[]
}

model Cursos {
  id           Int       @id @default(autoincrement())
  nome         String    @unique
  professor    String?
  cargaHoraria Int
  descricao    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  alunos AlunosCursos[]
}

model AlunosCursos {
     id        Int      @id @default(autoincrement())
  alunosId  Int
  cursosId  Int
  alunos    Alunos   @relation(fields: [alunosId], references: [id])
  cursos    Cursos   @relation(fields: [cursosId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Funcionarios{
  id Int @id @default(autoincrement())
  nome String
  email String @unique
  senha String 
  admin Boolean @default(false)
  createdAt  DateTime @default(now())
  updateAt DateTime @updatedAt
}